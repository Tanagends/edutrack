# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/edutrack

# JWT
JWT_SECRET=edutrack_super_secret_key_change_in_production
JWT_EXPIRE=7d

# Client
CLIENT_URL=http://localhost:5173

# Email (Nodemailer - use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=EduTrack <your_email@gmail.com>

# QR Token expiry (minutes)
QR_EXPIRE_MINUTES=10
